<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="10dp" android:background="@color/background">

    <!-- Stat card -->
    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="8dp"
        app:cardCornerRadius="14dp" app:cardElevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
            <ImageView android:id="@+id/ivIcon" android:layout_width="36dp" android:layout_height="36dp"
                android:contentDescription="icon"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
                <TextView android:id="@+id/tvTitle" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvNormalRange" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="11sp"
                    android:textColor="@color/textSecondary" android:layout_marginTop="2dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="end">
                <TextView android:id="@+id/tvLatest" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="20sp"
                    android:textStyle="bold" android:textColor="@color/colorPrimary"/>
                <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="11sp"
                    android:textColor="#fff" android:padding="4dp"
                    android:layout_marginTop="2dp" android:layout_gravity="end"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Chart card -->
    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        app:cardCornerRadius="14dp" app:cardElevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:padding="8dp">
            <com.github.mikephil.charting.charts.LineChart android:id="@+id/lineChart"
                android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
            <!-- Legend -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                <View android:layout_width="18dp" android:layout_height="3dp"
                    android:background="@color/colorPrimary" android:layout_marginEnd="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/legend_value" android:textSize="11sp" android:layout_marginEnd="14dp"/>
                <View android:layout_width="18dp" android:layout_height="2dp"
                    android:background="@color/limit_color" android:layout_marginEnd="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/legend_normal" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView android:id="@+id/noData" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="@string/no_data"
        android:textSize="14sp" android:textColor="@color/textSecondary"
        android:gravity="center" android:padding="32dp" android:visibility="gone"/>
</LinearLayout>
